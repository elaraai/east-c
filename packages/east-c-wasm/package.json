{
    "name": "@elaraai/east-c-wasm",
    "version": "0.1.1-beta.11",
    "description": "WebAssembly build of east-c for fast East IR execution",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "default": "./dist/src/index.js"
        },
        "./browser": {
            "types": "./dist/src/browser.d.ts",
            "default": "./dist/src/browser.js"
        },
        "./common": {
            "types": "./dist/src/common.d.ts",
            "default": "./dist/src/common.js"
        },
        "./east-c.wasm": "./dist/wasm/east-c.wasm",
        "./glue": "./dist/wasm/east-c.js"
    },
    "files": [
        "dist/src",
        "dist/wasm",
        "!dist/src/**/*.spec.*",
        "LICENSE.md",
        "CLA.md",
        "CONTRIBUTING.md"
    ],
    "scripts": {
        "build": "tsc",
        "test": "npm run build && node --enable-source-maps --test 'dist/test/wasm.spec.js'",
        "test:compliance": "npm run build && node --enable-source-maps --test 'dist/test/compliance.spec.js'",
        "test:all": "npm run build && node --enable-source-maps --test 'dist/test/**/*.spec.js'",
        "lint": "eslint .",
        "package": "npm run build && mkdir -p .package && npm pack --pack-destination .package"
    },
    "author": "Elara AI Pty Ltd",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/elaraai/east-c",
        "directory": "packages/east-c-wasm"
    },
    "type": "module",
    "engines": {
        "node": ">=22.0.0"
    },
    "peerDependencies": {
        "@elaraai/east": "beta"
    },
    "devDependencies": {
        "@elaraai/east": "beta",
        "@elaraai/east-node-std": "^0.0.1-beta.38",
        "@types/emscripten": "^1.41.5",
        "@types/node": "^22.18.1",
        "typescript": "^5.8.3"
    }
}
